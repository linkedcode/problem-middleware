{
    "name": "linkedcode/problem-middleware",
    "description": "Problem Details Middleware",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0",
        "slim/slim": "^4.0",
        "phpunit/phpunit": "^11"
    },
    "suggest": {
        "psr/http-server-handler": "Required by applications to run PSR-15 middleware pipelines"
    },
    "autoload": {
        "psr-4": {
            "Linkedcode\\Middleware\\Problem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Linkedcode\\Middleware\\Problem\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:html": "phpunit --testdox-html build/report/index.html",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html build/coverage"
    },
    "authors": [
        {
            "name": "Nicolas H. Kosciuk",
            "email": "info@linkedcode.com"
        }
    ]
}
